rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.participantIds;
    }

    // MARK: - Users

    match /users/{userId} {
      // Temporary:
      // Keep authenticated reads for phone duplicate check.
      allow read: if signedIn();

      allow create: if isOwner(userId)
        && (
          request.resource.data.role == "user"
          || request.resource.data.role == "expert"
        );

      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;

      allow delete: if false;

      // Owner-only user subcollections:
      // addresses, preferences, profile, favorites, paymentMethods, etc.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // MARK: - Reviews

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if signedIn()
        // Allow only known review fields.
        && request.resource.data.keys().hasAll([
          "reviewId",
          "bookingId",
          "reservationId",
          "customerId",
          "providerId",
          "rating",
          "comment",
          "categoryRatings",
          "photos",
          "isReported",
          "createdAt",
          "updatedAt",
          "helpfulCount",
          "helpfulUsers",
          "customerName",
          "isVerifiedBooking"
        ])
        && request.resource.data.keys().hasOnly([
          "reviewId",
          "bookingId",
          "reservationId",
          "serviceId",
          "serviceTitle",
          "customerId",
          "providerId",
          "rating",
          "comment",
          "categoryRatings",
          "photos",
          "isReported",
          "createdAt",
          "updatedAt",
          "helpfulCount",
          "helpfulUsers",
          "customerName",
          "customerAvatarURL",
          "isVerifiedBooking"
        ])

        // Validate ownership and IDs.
        && request.resource.data.reviewId == reviewId
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.bookingId is string
        && request.resource.data.reservationId is string
        && request.resource.data.reservationId
          == request.resource.data.bookingId
        && request.resource.data.providerId is string
        && request.resource.data.providerId.size() > 0

        // Validate review content.
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 500
        && request.resource.data.categoryRatings is map
        && request.resource.data.photos is list
        && request.resource.data.photos.size() <= 5
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && request.resource.data.customerName.size() <= 100

        // Validate initial state.
        && request.resource.data.isReported == false
        && request.resource.data.helpfulCount == 0
        && request.resource.data.helpfulUsers is list
        && request.resource.data.helpfulUsers.size() == 0
        && request.resource.data.isVerifiedBooking is bool
        && (
          // General review without a reservation.
          (
            request.resource.data.bookingId == ""
            && request.resource.data.reservationId == ""
            && request.resource.data.isVerifiedBooking == false
          )

          ||

          // Verified review for a completed reservation.
          (
            request.resource.data.bookingId.size() > 0
            && request.resource.data.reservationId
              == request.resource.data.bookingId
            && request.resource.data.isVerifiedBooking == true
            && exists(
              /databases/$(database)/documents/reservations/$(request.resource.data.bookingId)
            )
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.bookingId)
            ).data.customerId == request.auth.uid
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.bookingId)
            ).data.providerId == request.resource.data.providerId
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.bookingId)
            ).data.status == "completed"
          )
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if signedIn()
        && (
          // Provider can answer their own review once.
          (
            request.auth.uid == resource.data.providerId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "providerResponse",
              "providerResponseDate",
              "updatedAt"
            ])
            && request.resource.data.providerResponse is string
            && request.resource.data.providerResponse.size() > 0
            && request.resource.data.providerResponse.size() <= 400
            && request.resource.data.providerResponseDate is timestamp
            && request.resource.data.updatedAt is timestamp
            && (
              !resource.data.keys().hasAny(["providerResponse"])
              || resource.data.providerResponse == null
              || resource.data.providerResponse == ""
            )
          )

          ||

          // Signed-in users can toggle only their own helpful state.
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "helpfulUsers",
              "helpfulCount"
            ])
            && resource.data.helpfulUsers is list
            && resource.data.helpfulCount is int
            && resource.data.helpfulCount
              == resource.data.helpfulUsers.size()
            && request.resource.data.helpfulUsers is list
            && request.resource.data.helpfulCount is int
            && request.resource.data.helpfulCount >= 0
            && request.resource.data.helpfulCount
              == request.resource.data.helpfulUsers.size()
            && request.resource.data.helpfulUsers.toSet().size()
              == request.resource.data.helpfulUsers.size()
            && (
              (
                !(request.auth.uid in resource.data.helpfulUsers)
                && request.auth.uid in request.resource.data.helpfulUsers
                && request.resource.data.helpfulCount
                  == resource.data.helpfulCount + 1
                && request.resource.data.helpfulUsers.toSet()
                  .difference(resource.data.helpfulUsers.toSet())
                  .hasOnly([request.auth.uid])
                && resource.data.helpfulUsers.toSet()
                  .difference(request.resource.data.helpfulUsers.toSet())
                  .size() == 0
              )
              ||
              (
                request.auth.uid in resource.data.helpfulUsers
                && !(request.auth.uid in request.resource.data.helpfulUsers)
                && request.resource.data.helpfulCount
                  == resource.data.helpfulCount - 1
                && resource.data.helpfulUsers.toSet()
                  .difference(request.resource.data.helpfulUsers.toSet())
                  .hasOnly([request.auth.uid])
                && request.resource.data.helpfulUsers.toSet()
                  .difference(resource.data.helpfulUsers.toSet())
                  .size() == 0
              )
            )
          )

          ||

          // Signed-in users can only report a review.
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "isReported",
              "reportReason",
              "updatedAt"
            ])
            && request.resource.data.isReported == true
            && request.resource.data.reportReason is string
            && request.resource.data.reportReason.size() > 0
            && request.resource.data.reportReason.size() <= 1000
            && request.resource.data.updatedAt is timestamp
          )
        );

      allow delete: if false;
    }

    // MARK: - Services
    match /services/{serviceId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.providerId == request.auth.uid;

      allow update: if signedIn()
        && resource.data.providerId == request.auth.uid
        && request.resource.data.providerId == resource.data.providerId;

      allow delete: if signedIn()
        && resource.data.providerId == request.auth.uid;
    }

    // MARK: - Service Providers

    match /service_providers/{providerId} {
      allow read: if signedIn();
      allow create: if isOwner(providerId);
      allow update: if signedIn();
      allow delete: if false;
    }

    // MARK: - Reservations

    match /reservations/{reservationId} {
      allow read: if signedIn()
        && (
          resource.data.customerId == request.auth.uid
          || resource.data.providerId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == "pending"
        && exists(
          /databases/$(database)/documents/services/$(request.resource.data.serviceId)
        )
        && get(
          /databases/$(database)/documents/services/$(request.resource.data.serviceId)
        ).data.providerId == request.resource.data.providerId
        && get(
          /databases/$(database)/documents/services/$(request.resource.data.serviceId)
        ).data.isActive == true
        && (
          !get(
            /databases/$(database)/documents/services/$(request.resource.data.serviceId)
          ).data.keys().hasAny(["isAvailable"])
          ||
          get(
            /databases/$(database)/documents/services/$(request.resource.data.serviceId)
          ).data.isAvailable == true
        )
        && exists(
          /databases/$(database)/documents/service_providers/$(request.resource.data.providerId)
        )
        && (
          !get(
            /databases/$(database)/documents/service_providers/$(request.resource.data.providerId)
          ).data.keys().hasAny(["isAvailable"])
          ||
          get(
            /databases/$(database)/documents/service_providers/$(request.resource.data.providerId)
          ).data.isAvailable == true
        )
        && request.resource.data.keys().hasAll([
          "reservationId",
          "serviceId",
          "serviceTitle",
          "servicePrice",
          "serviceDuration",
          "providerId",
          "providerName",
          "customerId",
          "customerName",
          "reservationDate",
          "addressText",
          "note",
          "status",
          "createdAt",
          "updatedAt"
        ]);

      allow update: if signedIn()
        && request.resource.data.updatedAt is timestamp
        && (
          (
            resource.data.customerId == request.auth.uid
            && resource.data.status in ["pending", "accepted"]
            && request.resource.data.status == "cancelled"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt"
            ])
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "pending"
            && request.resource.data.status == "accepted"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt"
            ])
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "pending"
            && request.resource.data.status == "rejected"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt",
              "rejectionReason"
            ])
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectionReason.size() > 0
            && request.resource.data.rejectionReason.size() <= 200
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "accepted"
            && request.resource.data.status == "inProgress"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt",
              "startedAt"
            ])
            && request.resource.data.startedAt is timestamp
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "accepted"
            && request.resource.data.status == "noShow"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt",
              "noShowAt"
            ])
            && request.resource.data.noShowAt is timestamp
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "inProgress"
            && request.resource.data.status == "completed"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "status",
              "updatedAt",
              "completedAt"
            ])
            && request.resource.data.completedAt is timestamp
          )
        );

      allow delete: if false;
    }

    // MARK: - Provider Booked Slots

    match /provider_booked_slots/{providerId} {
      allow get, list: if signedIn();

      match /dates/{dateKey} {
        allow get, list: if signedIn();

        match /times/{timeKey} {
          allow get, list: if signedIn();

          allow create: if signedIn()
            && request.resource.data.providerId == providerId
            && request.resource.data.dateKey == dateKey
            && request.resource.data.status == "pending"
            && request.resource.data.reservationId is string
            && request.resource.data.timeString is string
            && request.resource.data.keys().hasAll([
              "providerId",
              "dateKey",
              "timeString",
              "status",
              "reservationId",
              "createdAt",
              "updatedAt"
            ])
            && request.resource.data.keys().hasOnly([
              "providerId",
              "dateKey",
              "timeString",
              "status",
              "reservationId",
              "createdAt",
              "updatedAt"
            ])
            && exists(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            )
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.customerId == request.auth.uid
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.providerId == providerId
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.status == "pending";

          allow update: if signedIn()
            && (
              (
                resource.data.status in ["cancelled", "rejected"]
                && request.resource.data.providerId == providerId
                && request.resource.data.providerId == resource.data.providerId
                && request.resource.data.dateKey == dateKey
                && request.resource.data.dateKey == resource.data.dateKey
                && request.resource.data.timeString == resource.data.timeString
                && request.resource.data.status == "pending"
                && request.resource.data.reservationId is string
                && request.resource.data.keys().hasAll([
                  "providerId",
                  "dateKey",
                  "timeString",
                  "status",
                  "reservationId",
                  "createdAt",
                  "updatedAt"
                ])
                && request.resource.data.keys().hasOnly([
                  "providerId",
                  "dateKey",
                  "timeString",
                  "status",
                  "reservationId",
                  "createdAt",
                  "updatedAt"
                ])
                && exists(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                )
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.customerId == request.auth.uid
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.providerId == providerId
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.status == "pending"
              )
              ||
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  "status",
                  "updatedAt"
                ])
                && request.resource.data.providerId == resource.data.providerId
                && request.resource.data.dateKey == resource.data.dateKey
                && request.resource.data.timeString == resource.data.timeString
                && request.resource.data.reservationId == resource.data.reservationId
                && request.resource.data.status in [
                  "accepted",
                  "rejected",
                  "cancelled",
                  "inProgress",
                  "completed",
                  "noShow"
                ]
                && getAfter(
                  /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                ).data.providerId == providerId
                && getAfter(
                  /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                ).data.status == request.resource.data.status
                && (
                  (
                    getAfter(
                      /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                    ).data.customerId == request.auth.uid
                    && request.resource.data.status == "cancelled"
                  )
                  ||
                  (
                    getAfter(
                      /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                    ).data.providerId == request.auth.uid
                    && request.resource.data.status in [
                      "accepted",
                      "rejected",
                      "inProgress",
                      "completed",
                      "noShow"
                    ]
                  )
                )
              )
            );

          allow delete: if false;
        }
      }
    }

    // MARK: - Conversations

    match /conversations/{conversationId} {
      allow get: if signedIn()
        && (
          !exists(/databases/$(database)/documents/conversations/$(conversationId))
          || request.auth.uid in resource.data.participantIds
        );

      allow list: if signedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.keys().hasOnly([
          "participantIds",
          "participantNames",
          "participantPhotoURLs",
          "lastMessage",
          "lastMessageAt",
          "unreadCounts",
          "createdAt",
          "updatedAt"
        ]);

      allow update: if signedIn()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastMessage",
          "lastMessageAt",
          "updatedAt",
          "unreadCounts"
        ]);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderId in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds
          && request.resource.data.receiverId in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds
          && request.resource.data.senderId != request.resource.data.receiverId
          && request.resource.data.conversationId == conversationId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.isRead == false
          && request.resource.data.keys().hasOnly([
            "conversationId",
            "senderId",
            "receiverId",
            "text",
            "sentAt",
            "isRead"
          ]);

        allow update: if isConversationParticipant(conversationId)
          && resource.data.receiverId == request.auth.uid
          && resource.data.isRead == false
          && request.resource.data.isRead == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "isRead"
          ]);

        allow delete: if false;
      }
    }
  }
}
