rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && request.auth.uid in get(
          /databases/$(database)/documents/conversations/$(conversationId)
        ).data.participantIds;
    }

    // MARK: - Users

    match /users/{userId} {
      // Temporary:
      // Keep authenticated reads for phone duplicate check.
      allow read: if signedIn();

      allow create: if isOwner(userId)
        && (
          request.resource.data.role == "user"
          || request.resource.data.role == "expert"
        );

      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role;

      allow delete: if false;

      // Owner-only user subcollections:
      // addresses, preferences, profile, favorites, paymentMethods, etc.
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // MARK: - Services

    match /services/{serviceId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.providerId == request.auth.uid;

      allow update: if signedIn()
        && resource.data.providerId == request.auth.uid
        && request.resource.data.providerId == resource.data.providerId;

      allow delete: if signedIn()
        && resource.data.providerId == request.auth.uid;
    }

    // MARK: - Service Providers

    match /service_providers/{providerId} {
      allow read: if signedIn();

      allow create: if isOwner(providerId);

      allow update: if isOwner(providerId);

      allow delete: if false;
    }

    // MARK: - Reservations

    match /reservations/{reservationId} {
      allow read: if signedIn()
        && (
          resource.data.customerId == request.auth.uid
          || resource.data.providerId == request.auth.uid
        );

      allow create: if signedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.keys().hasAll([
          "reservationId",
          "serviceId",
          "serviceTitle",
          "servicePrice",
          "serviceDuration",
          "providerId",
          "providerName",
          "customerId",
          "customerName",
          "reservationDate",
          "addressText",
          "note",
          "status",
          "createdAt",
          "updatedAt"
        ]);

      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "status",
          "updatedAt",
          "rejectionReason"
        ])
        && (
          (
            resource.data.customerId == request.auth.uid
            && resource.data.status in ["pending", "accepted"]
            && request.resource.data.status == "cancelled"
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "pending"
            && (
              request.resource.data.status == "accepted"
              ||
              (
                request.resource.data.status == "rejected"
                && request.resource.data.rejectionReason is string
                && request.resource.data.rejectionReason.size() > 0
                && request.resource.data.rejectionReason.size() <= 200
              )
            )
          )
          ||
          (
            resource.data.providerId == request.auth.uid
            && resource.data.status == "accepted"
            && request.resource.data.status == "completed"
            && resource.data.reservationDate <= request.time
          )
        );

      allow delete: if false;
    }

    // MARK: - Reviews

    match /reviews/{reviewId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          "reviewId",
          "reservationId",
          "providerId",
          "customerId",
          "customerName",
          "serviceId",
          "serviceTitle",
          "rating",
          "comment",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.keys().hasOnly([
          "reviewId",
          "reservationId",
          "providerId",
          "customerId",
          "customerName",
          "serviceId",
          "serviceTitle",
          "rating",
          "comment",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.reviewId == reviewId
        && request.resource.data.reservationId == reviewId
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && exists(
          /databases/$(database)/documents/reservations/$(reviewId)
        )
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.customerId == request.auth.uid
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.status == "completed"
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.providerId == request.resource.data.providerId
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.serviceId == request.resource.data.serviceId
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.serviceTitle == request.resource.data.serviceTitle
        && get(
          /databases/$(database)/documents/reservations/$(reviewId)
        ).data.customerName == request.resource.data.customerName;

      allow update: if signedIn()
        && resource.data.providerId == request.auth.uid
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            "providerResponse",
            "providerResponseAt",
            "updatedAt"
          ])
        && (
          !resource.data.keys().hasAny(["providerResponse"])
          || resource.data.providerResponse == ""
        )
        && request.resource.data.providerResponse is string
        && request.resource.data.providerResponse.size() > 0
        && request.resource.data.providerResponse.size() <= 500
        && request.resource.data.providerResponseAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow delete: if false;
    }

    // MARK: - Provider Booked Slots

    match /provider_booked_slots/{providerId} {
      allow get, list: if signedIn();

      match /dates/{dateKey} {
        allow get, list: if signedIn();

        match /times/{timeKey} {
          allow get, list: if signedIn();

          allow create: if signedIn()
            && request.resource.data.providerId == providerId
            && request.resource.data.dateKey == dateKey
            && request.resource.data.status == "pending"
            && request.resource.data.reservationId is string
            && request.resource.data.timeString is string
            && request.resource.data.keys().hasAll([
              "providerId",
              "dateKey",
              "timeString",
              "status",
              "reservationId",
              "createdAt",
              "updatedAt"
            ])
            && request.resource.data.keys().hasOnly([
              "providerId",
              "dateKey",
              "timeString",
              "status",
              "reservationId",
              "createdAt",
              "updatedAt"
            ])
            && exists(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            )
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.customerId == request.auth.uid
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.providerId == providerId
            && get(
              /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
            ).data.status == "pending";

          allow update: if signedIn()
            && (
              (
                resource.data.status in ["cancelled", "rejected"]
                && request.resource.data.providerId == providerId
                && request.resource.data.providerId == resource.data.providerId
                && request.resource.data.dateKey == dateKey
                && request.resource.data.dateKey == resource.data.dateKey
                && request.resource.data.timeString == resource.data.timeString
                && request.resource.data.status == "pending"
                && request.resource.data.reservationId is string
                && request.resource.data.keys().hasAll([
                  "providerId",
                  "dateKey",
                  "timeString",
                  "status",
                  "reservationId",
                  "createdAt",
                  "updatedAt"
                ])
                && request.resource.data.keys().hasOnly([
                  "providerId",
                  "dateKey",
                  "timeString",
                  "status",
                  "reservationId",
                  "createdAt",
                  "updatedAt"
                ])
                && exists(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                )
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.customerId == request.auth.uid
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.providerId == providerId
                && get(
                  /databases/$(database)/documents/reservations/$(request.resource.data.reservationId)
                ).data.status == "pending"
              )
              ||
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                  "status",
                  "updatedAt"
                ])
                && request.resource.data.providerId == resource.data.providerId
                && request.resource.data.dateKey == resource.data.dateKey
                && request.resource.data.timeString == resource.data.timeString
                && request.resource.data.reservationId == resource.data.reservationId
                && request.resource.data.status in [
                  "accepted",
                  "rejected",
                  "cancelled",
                  "completed"
                ]
                && getAfter(
                  /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                ).data.providerId == providerId
                && getAfter(
                  /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                ).data.status == request.resource.data.status
                && (
                  (
                    getAfter(
                      /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                    ).data.customerId == request.auth.uid
                    && request.resource.data.status == "cancelled"
                  )
                  ||
                  (
                    getAfter(
                      /databases/$(database)/documents/reservations/$(resource.data.reservationId)
                    ).data.providerId == request.auth.uid
                    && request.resource.data.status in [
                      "accepted",
                      "rejected",
                      "completed"
                    ]
                  )
                )
              )
            );

          allow delete: if false;
        }
      }
    }

    // MARK: - Conversations

    match /conversations/{conversationId} {
      allow get: if signedIn()
        && (
          !exists(/databases/$(database)/documents/conversations/$(conversationId))
          || request.auth.uid in resource.data.participantIds
        );

      allow list: if signedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if signedIn()
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantIds.size() == 2
        && request.resource.data.keys().hasOnly([
          "participantIds",
          "participantNames",
          "participantPhotoURLs",
          "lastMessage",
          "lastMessageAt",
          "unreadCounts",
          "createdAt",
          "updatedAt"
        ]);

      allow update: if signedIn()
        && request.auth.uid in resource.data.participantIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastMessage",
          "lastMessageAt",
          "updatedAt",
          "unreadCounts"
        ]);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(conversationId);

        allow create: if isConversationParticipant(conversationId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.senderId in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds
          && request.resource.data.receiverId in get(
            /databases/$(database)/documents/conversations/$(conversationId)
          ).data.participantIds
          && request.resource.data.senderId != request.resource.data.receiverId
          && request.resource.data.conversationId == conversationId
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000
          && request.resource.data.isRead == false
          && request.resource.data.keys().hasOnly([
            "conversationId",
            "senderId",
            "receiverId",
            "text",
            "sentAt",
            "isRead"
          ]);

        allow update: if isConversationParticipant(conversationId)
          && resource.data.receiverId == request.auth.uid
          && resource.data.isRead == false
          && request.resource.data.isRead == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "isRead"
          ]);

        allow delete: if false;
      }
    }
  }
}
