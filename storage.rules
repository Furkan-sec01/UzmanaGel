rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isImageUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches(
          'image/(jpeg|png|heic|heif|webp)'
        );
    }

    function isDocumentUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && request.resource.contentType.matches(
          'image/(jpeg|png|heic|heif|webp)|application/pdf'
        );
    }

    // Review photos
    match /review_photos/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(userId)
        && isImageUpload(10 * 1024 * 1024);

      allow delete: if false;
    }

    // Portfolio photos
    match /portfolio/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(userId)
        && isImageUpload(10 * 1024 * 1024);

      allow delete: if false;
    }

    // Listing photos
    match /listing_images/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(userId)
        && isImageUpload(10 * 1024 * 1024);

      allow delete: if false;
    }

    // Profile photos
    match /profile_photos/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(userId)
        && isImageUpload(5 * 1024 * 1024);

      allow delete: if false;
    }

    // Current flat profile image path: profile_images/{uid}.jpg
    match /profile_images/{fileName} {
      allow read: if true;

      allow create, update: if signedIn()
        && fileName == request.auth.uid + ".jpg"
        && isImageUpload(5 * 1024 * 1024);

      allow delete: if false;
    }

    // Legacy nested profile image path
    match /profile_images/{userId}/{fileName} {
      allow read: if true;

      allow create, update: if isOwner(userId)
        && isImageUpload(5 * 1024 * 1024);

      allow delete: if false;
    }

    // Certificates
    match /certificates/{userId}/{fileName} {
      allow read: if isOwner(userId);

      allow create, update: if isOwner(userId)
        && isDocumentUpload(20 * 1024 * 1024);

      allow delete: if false;
    }

    // Identity and verification documents
    match /verification_documents/{userId}/{fileName} {
      allow read: if isOwner(userId);

      allow create, update: if isOwner(userId)
        && isDocumentUpload(20 * 1024 * 1024);

      allow delete: if false;
    }

    // Legacy service images are read-only.
    match /service_images/{serviceId}/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    // Deny every unknown path.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
